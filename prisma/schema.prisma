generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntityType {
  PERSON
  ORGANIZATION
  GROUP
  DUO
  TRIO
  WORK
  EVENT
  PLACE
  CONCEPT
  OTHER
}

enum RelationshipDirection {
  DIRECTED
  UNDIRECTED
  BIDIRECTIONAL
}

model Project {
  id                     String          @id @default(cuid())
  slug                   String          @unique
  name                   String
  description            String?
  defaultTimelinePointId String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  entities               Entity[]
  timelinePoints         TimelinePoint[]
  relationships          Relationship[]
  views                  View[]
}

model Entity {
  id          String         @id @default(cuid())
  projectId   String
  slug        String
  name        String
  entityType  EntityType
  description String?
  image       String?
  aliases     String[]
  tags        String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  states      EntityState[]
  sourceRels  Relationship[] @relation("RelationshipSource")
  targetRels  Relationship[] @relation("RelationshipTarget")
  viewNodes   ViewNode[]

  @@unique([projectId, slug])
}

model TimelinePoint {
  id                 String              @id @default(cuid())
  projectId          String
  label              String
  sortOrder          Int
  startDate          DateTime?
  endDate            DateTime?
  description        String?
  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entityStates       EntityState[]
  relationshipStates RelationshipState[]

  @@unique([projectId, sortOrder])
}

model EntityState {
  id                  String        @id @default(cuid())
  entityId            String
  timelinePointId     String
  nameOverride        String?
  descriptionOverride String?
  imageOverride       String?
  affiliation         String?
  role                String?
  attributes          Json?
  entity              Entity        @relation(fields: [entityId], references: [id], onDelete: Cascade)
  timelinePoint       TimelinePoint @relation(fields: [timelinePointId], references: [id], onDelete: Cascade)

  @@unique([entityId, timelinePointId])
}

model Relationship {
  id               String                @id @default(cuid())
  projectId        String
  sourceEntityId   String
  targetEntityId   String
  relationshipType String
  label            String
  direction        RelationshipDirection
  description      String?
  evidence         String?
  confidence       Float?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  project          Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceEntity     Entity                @relation("RelationshipSource", fields: [sourceEntityId], references: [id])
  targetEntity     Entity                @relation("RelationshipTarget", fields: [targetEntityId], references: [id])
  states           RelationshipState[]
  viewEdges        ViewEdge[]
}

model RelationshipState {
  id                  String        @id @default(cuid())
  relationshipId      String
  timelinePointId     String
  isActive            Boolean?
  labelOverride       String?
  descriptionOverride String?
  strength            Float?
  sentiment           String?
  relationship        Relationship  @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  timelinePoint       TimelinePoint @relation(fields: [timelinePointId], references: [id], onDelete: Cascade)

  @@unique([relationshipId, timelinePointId])
}

model View {
  id              String       @id @default(cuid())
  projectId       String
  name            String
  description     String?
  centerEntityId  String?
  timelinePointId String?
  depth           Int          @default(1)
  theme           String?
  filters         Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodes           ViewNode[]
  edges           ViewEdge[]
  groups          VisualGroup[]
  annotations     Annotation[]
}

model ViewNode {
  id             String  @id @default(cuid())
  viewId         String
  entityId       String
  x              Float
  y              Float
  width          Float
  height         Float
  zIndex         Int     @default(1)
  groupId        String?
  isPinned       Boolean @default(false)
  isHidden       Boolean @default(false)
  displayVariant String?
  view           View    @relation(fields: [viewId], references: [id], onDelete: Cascade)
  entity         Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

model ViewEdge {
  id             String       @id @default(cuid())
  viewId         String
  relationshipId String
  labelOverride  String?
  lineStyle      String?
  color          String?
  route          Json?
  isHidden       Boolean      @default(false)
  view           View         @relation(fields: [viewId], references: [id], onDelete: Cascade)
  relationship   Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
}

model VisualGroup {
  id          String  @id @default(cuid())
  viewId      String
  name        String
  description String?
  color       String
  x           Float
  y           Float
  width       Float
  height      Float
  zIndex      Int     @default(0)
  view        View    @relation(fields: [viewId], references: [id], onDelete: Cascade)
}

model Annotation {
  id                   String  @id @default(cuid())
  viewId               String
  text                 String
  x                    Float
  y                    Float
  width                Float
  height               Float
  style                String?
  linkedEntityId       String?
  linkedRelationshipId String?
  view                 View    @relation(fields: [viewId], references: [id], onDelete: Cascade)
}
